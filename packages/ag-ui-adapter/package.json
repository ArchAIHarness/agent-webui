{
  "name": "@archai/agent-webui-ag-ui-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "Adapter that converts OpenCode Web API events into AG-UI event stream over Hono.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-webui-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@archai/agent-webui-shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
