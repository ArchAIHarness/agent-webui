{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/browser-types",
    "rootDir": "./src/browser",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx"
  },
  "include": ["src/browser/**/*"]
}
